## 4. Randomised Question Engine

This is a core technical requirement. Questions must be **genuinely random** on every session — not cycled from a fixed list.

### 4.1 Fraction Generator Algorithm

```javascript
// utils/fractionGenerator.js

const DENOMINATORS = [2, 3, 4, 5, 6, 8, 10]

/**
 * Generate a random like-fraction addition problem
 * Ensures result ≤ 1 (no improper fractions in Grade 3)
 */
export function generateAddition() {
  const denom = DENOMINATORS[Math.floor(Math.random() * DENOMINATORS.length)]
  const a = Math.floor(Math.random() * (denom - 1)) + 1   // 1 to denom-1
  const maxB = denom - a                                   // ensure a+b ≤ denom
  const b = Math.floor(Math.random() * maxB) + 1          // 1 to maxB

  return {
    type: 'addition',
    a, b, denom,
    answer: a + b,
    equation: `${a}/${denom} + ${b}/${denom} = ?`,
    display: { numerator: a + b, denominator: denom }
  }
}

/**
 * Generate a random like-fraction subtraction problem
 * Ensures result > 0
 */
export function generateSubtraction() {
  const denom = DENOMINATORS[Math.floor(Math.random() * DENOMINATORS.length)]
  const a = Math.floor(Math.random() * (denom - 1)) + 2   // 2 to denom
  const b = Math.floor(Math.random() * (a - 1)) + 1       // 1 to a-1

  return {
    type: 'subtraction',
    a, b, denom,
    answer: a - b,
    equation: `${a}/${denom} − ${b}/${denom} = ?`,
    display: { numerator: a - b, denominator: denom }
  }
}

/**
 * Generate wrong answer distractors (plausible but incorrect)
 */
export function generateDistractors(correct, denom, type) {
  const distractors = new Set()

  // Common mistake: add/subtract denominators too
  if (type === 'addition') distractors.add(`${correct.num + 1}/${correct.denom + 1}`)

  // Off-by-one in numerator
  if (correct.num > 1) distractors.add(`${correct.num - 1}/${correct.denom}`)
  distractors.add(`${correct.num + 1}/${correct.denom}`)

  // Return 2 unique distractors
  return [...distractors].slice(0, 2)
}

/**
 * Generate a full session of 10 shuffled questions
 * Mix: 5 addition, 3 subtraction, 2 word problems
 */
export function generatePracticeSession() {
  const questions = []

  for (let i = 0; i < 5; i++) questions.push({ ...generateAddition(), questionType: 'equation' })
  for (let i = 0; i < 3; i++) questions.push({ ...generateSubtraction(), questionType: 'equation' })
  for (let i = 0; i < 2; i++) {
    const base = Math.random() > 0.5 ? generateAddition() : generateSubtraction()
    questions.push({ ...base, questionType: 'word-problem' })
  }

  // Fisher-Yates shuffle
  for (let i = questions.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [questions[i], questions[j]] = [questions[j], questions[i]]
  }

  return questions
}
```

