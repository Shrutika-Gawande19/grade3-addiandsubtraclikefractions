    xp_earned: xp,
    stars_earned: stars,
    badges_unlocked: badges,
    completed_at: new Date().toISOString()
  }

  try {
    const res = await fetch('https://intelliasg.com/api/v1/lesson-complete', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${window.__INTELLIA_TOKEN__}`  // injected by LMS
      },
      body: JSON.stringify(payload)
    })
    return res.ok
  } catch {
    // Non-blocking — lesson still works offline
    console.warn('Score submission failed; saved to localStorage for retry')
    localStorage.setItem('pending-score', JSON.stringify(payload))
    return false
  }
}
