## 6. Audio System — Technical Specification

### 6.1 Howler.js Implementation

```javascript
// hooks/useAudio.js
import { Howl, Howler } from 'howler'
import { useAudioStore } from '../store/audioStore'

const sounds = {
  'leo-intro':    new Howl({ src: ['/audio/leo-intro.mp3'], preload: true }),
  'leo-scene1':   new Howl({ src: ['/audio/leo-scene1.mp3'], preload: true }),
  'sfx-correct':  new Howl({ src: ['/audio/sfx-correct.mp3'], volume: 0.6 }),
  'sfx-wrong':    new Howl({ src: ['/audio/sfx-wrong.mp3'], volume: 0.4 }),
  'sfx-badge':    new Howl({ src: ['/audio/sfx-badge.mp3'], volume: 0.8 }),
  'sfx-confetti': new Howl({ src: ['/audio/sfx-confetti.mp3'], volume: 0.7 }),
}

export function useAudio() {
  const { muted } = useAudioStore()

  const play = (key) => {
    if (!muted && sounds[key]) sounds[key].play()
  }

  const stopAll = () => {
    Object.values(sounds).forEach(s => s.stop())
  }

  return { play, stopAll }
}
```

